{
    "name": "brodos/picoagents-php",
    "description": "PHP port of PicoAgents — a lightweight multi-agent framework for AI agents, orchestrators, and workflows. Based on Victor Dibia's designing-multiagent-systems.",
    "keywords": [
        "brodos",
        "picoagents-php"
    ],
    "homepage": "https://github.com/brodos/picoagents-php",
    "license": "MIT",
    "authors": [
        {
            "name": "Lucian Brodos",
            "email": "brodos@outlook.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3|^8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.3.2",
        "friendsofphp/php-cs-fixer": "^3.21.1",
        "spatie/ray": "^1.28"
    },
    "autoload": {
        "psr-4": {
            "Brodos\\PicoAgents\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brodos\\PicoAgents\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
            "test-coverage": "vendor/bin/phpunit --configuration phpunit.coverage.xml.dist",
        "format": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --allow-risky=yes"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {

            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
